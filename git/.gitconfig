# Machine-specific settings (user identity, signing key, gpg binary path)
# live in ~/.gitconfig.local, which is not tracked in this repo.
[include]
	path = ~/.gitconfig.local

[core]
	editor = nvim
	excludesFile = ~/.gitignore

[alias]
	propen = "!f() { git push -u origin $(git branch --show-current); }; f"
	nono = !git reset --hard && git clean -df
	please = push --force-with-lease

[color]
	ui = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = blue
	frag = magenta bold
	func = 146 bold
	commit = blue bold
	old = red bold
	new = green bold
	whitespace = red reverse

[diff]
	algorithm = histogram

[commit]
	gpgsign = true
	template = ~/.gitmessage

[push]
	autoSetupRemote = true
